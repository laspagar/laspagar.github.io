---
layout: none
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1">
  {% for post in site.posts %}
  <url>
    <loc>{{ post.url | absolute_url | xml_escape }}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
    {% if post.image %}
    <image:image>
      <image:loc>{{ post.image | absolute_url | xml_escape }}</image:loc>
      <image:title>{{ post.title | xml_escape }}</image:title>
      <image:caption>{{ post.excerpt | strip_html | truncate: 160 | xml_escape }}</image:caption>
    </image:image>
    {% endif %}
  </url>
  {% endfor %}
</urlset>
